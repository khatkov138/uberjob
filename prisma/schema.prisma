generator client {
  provider = "prisma-client-js"
  output   = "./generated"
}

datasource db {
  provider = "postgresql"
}

// --- ПОЛЬЗОВАТЕЛИ И РОЛИ ---
enum UserRole {
  USER
  ADMIN
  SUPERADMIN
}

model User {
  id            String   @id
  name          String
  email         String   @unique
  emailVerified Boolean  @default(false)
  image         String?
  role          UserRole @default(USER)

  // ФИНАНСЫ (в копейках)
  balance Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Связи Better-Auth
  sessions Session[]
  accounts Account[]

  // Профиль исполнителя
  profile Profile?

  // Заказы и отклики
  ordersCreated Order[] @relation("ClientOrders") // Заказы, где юзер — клиент
  ordersTaken   Order[] @relation("WorkerOrders") // Заказы, где юзер — выбранный исполнитель
  offers        Offer[] // Отклики, которые оставил юзер (как исполнитель)

  // История денег
  transactions Transaction[]

  // Общение и уведомления
  notifications Notification[]

  // ЧАТЫ: Именованные связи для отправителя и получателя
  sentMessages     Message[] @relation("SentMessages")
  receivedMessages Message[] @relation("ReceivedMessages")

  @@map("user")
}

model Profile {
  id     String @id @default(cuid())
  userId String @unique
  // Связь теперь общая, без привязки только к "Worker"
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // --- ОБЩИЕ ДАННЫЕ (Личность) ---
  phone     String? // Телефон для связи по заказам
  city      String? // Город проживания
  avatarUrl String? // Ссылка на фото (если не из соцсетей)
  bio       String? // Кратко о себе / Опыт работы

  // --- ПРОФЕССИОНАЛЬНЫЕ ДАННЫЕ (PRO) ---
  skills         String[] @default([]) // Массив навыков (Электрика, Сантехника и т.д.)
  rating         Float    @default(5.0)
 
  completedCount Int      @default(0) // Сколько заказов реально завершено

  // --- ГЕОПОЗИЦИЯ (Uber-механика) ---
  lastLat  Float?
  lastLng  Float?
  lastSeen DateTime @default(now())
  reviews  Review[]

  // --- СИСТЕМНЫЕ ПОЛЯ ---
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("profile")
}

// --- СИСТЕМА ЗАКАЗОВ ---

model Order {
  id        String      @id @default(cuid())
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  status    OrderStatus @default(PENDING)
  dateType  DateType    @default(ASAP)

  title       String
  description String
  categories  String[] // Храним названия категорий массивом
  price       Int // Бюджет в копейках
  address     String

  lat Float?
  lng Float?

  // Кто создал
  clientId String
  client   User   @relation("ClientOrders", fields: [clientId], references: [id])

  // Кто выполняет (выбирается из откликов)
  workerId String?
  worker   User?   @relation("WorkerOrders", fields: [workerId], references: [id])

  offers       Offer[] // Все предложения от исполнителей
  review       Review?
  messages     Message[]
  transactions Transaction[]

  @@map("order")
}

// МОДЕЛЬ ОТКЛИКА (Bid/Offer)
model Offer {
  id        String      @id @default(cuid())
  price     Int // Какую цену предложил исполнитель
  message   String? // Сопроводительный текст
  status    OfferStatus @default(PENDING)
  createdAt DateTime    @default(now())

  orderId String
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  workerId String
  worker   User   @relation(fields: [workerId], references: [id])

  @@map("offer")
}

// --- ФИНАНСОВЫЙ КОШЕЛЕК ---

model Transaction {
  id          String            @id @default(cuid())
  amount      Int // Сумма: положительная (приход), отрицательная (расход)
  type        TransactionType
  status      TransactionStatus @default(COMPLETED)
  description String? // "Оплата заказа #..." или "Пополнение через карту"
  createdAt   DateTime          @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id])

  orderId String?
  order   Order?  @relation(fields: [orderId], references: [id])

  @@map("transaction")
}

// --- СПРАВОЧНИКИ И ОТЗЫВЫ ---

model Category {
  id        String   @id @default(cuid())
  name      String   @unique
  keywords  String[] // Для умного поиска и пре-фильтрации ИИ
  createdAt DateTime @default(now())

  @@index([keywords]) // Ускоряет поиск, когда категорий станет много
  @@map("category")
}

model Review {
  id        String   @id @default(cuid())
  rating    Int
  comment   String?
  createdAt DateTime @default(now())

  orderId String @unique
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  profileId String
  profile   Profile @relation(fields: [profileId], references: [id])

  @@map("review")
}

// --- СЛУЖЕБНЫЕ ТАБЛИЦЫ ---

model Session {
  id        String   @id
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("verification")
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  title     String
  message   String
  type      String
  isRead    Boolean  @default(false)
  link      String?
  createdAt DateTime @default(now())

  @@map("notification")
}

model Message {
  id          String   @id @default(cuid())
  text        String
  createdAt   DateTime @default(now())
  isRead      Boolean  @default(false)

  // Кто отправил и кто получил (основная связь)
  senderId    String
  sender      User     @relation("SentMessages", fields: [senderId], references: [id])
  recipientId String
  recipient   User     @relation("ReceivedMessages", fields: [recipientId], references: [id])

  // Опциональная привязка к заказу (контекст)
  orderId     String?  // Ставим знак вопроса — теперь не обязательно!
  order       Order?   @relation(fields: [orderId], references: [id])

  @@index([senderId, recipientId])

  @@map ("message")
}


// --- ENUMS ---

enum OrderStatus {
  PENDING
  SEARCHING
  ACCEPTED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum OfferStatus {
  PENDING
  ACCEPTED
  REJECTED
}

enum DateType {
  ASAP
  SCHEDULED
}

enum TransactionType {
  DEPOSIT
  WITHDRAW
  PAYMENT
  EARNING
  HOLD
  REFUND
}

enum TransactionStatus {
  PENDING
  COMPLETED
  FAILED
}
